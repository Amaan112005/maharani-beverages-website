{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/about",
      "destination": "/pages/vision.html"
    },
    {
      "source": "/contact",
      "destination": "/pages/contact.html"
    },
    {
      "source": "/inquiry",
      "destination": "/pages/bulk.html"
    },
    {
      "source": "/careers",
      "destination": "/pages/careers.html"
    },
    {
      "source": "/vision",
      "destination": "/pages/vision.html"
    },
    {
      "source": "/bulk",
      "destination": "/pages/bulk.html"
    },
    {
      "source": "/distributor",
      "destination": "/pages/distributor.html"
    },
    {
      "source": "/comparison",
      "destination": "/pages/comparison.html"
    },
    {
      "source": "/compliance",
      "destination": "/pages/compliance.html"
    },
    {
      "source": "/privacy",
      "destination": "/pages/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/pages/terms.html"
    },
    {
      "source": "/shipping",
      "destination": "/pages/shipping.html"
    },
    {
      "source": "/returns",
      "destination": "/pages/returns.html"
    },
    {
      "source": "/enquiry-cart",
      "destination": "/pages/enquiry-cart.html"
    },
    {
      "source": "/products",
      "destination": "/pages/products.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: *; connect-src 'self' https://formspree.io; frame-src 'none'; object-src 'none';"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path(.*)\\.:ext(jpg|jpeg|png|gif|webp|avif|svg|ico|css|js)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path(.*)\\.:ext(woff|woff2|ttf|otf)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/:path(.*)\\.:ext(css|js)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/:path(.*)\\.:ext(webp|jpg|jpeg|png|gif|svg)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/udyam_certificate.pdf",
      "headers": [
        {
          "key": "Link",
          "value": "<https://maharanibeverages.com/udyam_certificate.pdf>; rel=\"canonical\""
        }
      ]
    }
  ]
}